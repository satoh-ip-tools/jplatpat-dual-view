{
  "manifest_version": 3,
  "name": "2列表示ビューア for J-PlatPat(非公式)",
  "version": "1.1.4",
  "description": "J-PlatPatの文献表示で「請求の範囲」と「詳細な説明」を左右2列表示にする非公式ツールです。個別スクロール・図面幅調整・キーワードハイライトに対応。INPIT公式の拡張機能ではありません。",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.j-platpat.inpit.go.jp/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}